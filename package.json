{
  "name": "pixelgrade",
  "description": "Inspect spacing, rulers, and guides on any page.",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "corepack pnpm --filter ./packages/mesurer build && corepack pnpm --filter ./apps/site build",
    "build:extension": "corepack pnpm --filter ./apps/site build",
    "build:site": "corepack pnpm --filter ./apps/site build",
    "build:pkg": "corepack pnpm --filter ./packages/mesurer build",
    "package:extension": "corepack pnpm --filter ./apps/site package",
    "dev": "corepack pnpm -r dev",
    "dev:extension": "corepack pnpm --filter ./apps/site dev",
    "dev:site": "corepack pnpm --filter ./apps/site dev",
    "dev:pkg": "corepack pnpm --filter ./packages/mesurer dev",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
